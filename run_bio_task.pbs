#!/bin/bash
# ===================== PBS Resource Configuration (Do not modify) =====================
#PBS -N bio_info_extract       # Task name (can modify, e.g., your script name)
#PBS -q fat                    # Use fat or normal queue (more idle nodes, priority to run)
#PBS -l nodes=node01.chess:ppn=200         # Node 01 (node name: node01.chess), 10 CPU cores
#PBS -l walltime=100:00:00    # Max run time 100 hours (terminate automatically if timeout)
#PBS -o /data7/sunxiuqiang/Biometric_Information_Extraction/task_run.log        # Normal output log
#PBS -e /data7/sunxiuqiang/Biometric_Information_Extraction/task_error.log      # Error log

# ===================== Only modify [your Python script name] below =====================
# 1. Activate py39 environment (path is your actual conda path, do not modify)

source /data/homebackup/sunxiuqiang/tools/miniconda3/etc/profile.d/conda.sh
conda activate py39

# 2. Enter project directory (confirm it's your actual path, do not modify)
cd /data7/sunxiuqiang/Biometric_Information_Extraction || exit  # Exit if cd fails

# 3. Check if input file exists
if [ ! -f "/data7/sunxiuqiang/Biometric_Information_Extraction/don_text_extracted.csv" ]; then
    echo "Error: Input file does not exist!"
    exit 1
fi

# 4. Run Python script (★ CRITICAL: \ must be the LAST character of each line, NO SPACES AFTER \ ★)
# NOTE:
# - progress_don.csv only tracks stage-1 extraction progress.
# - stage-2 unmatched backfill progress is written to task_run.log
#   (prints every 50 unique unmatched queries).

python -m app.batch_extract_csv_qwen_parallel \
--limit 0 \
--workers 195 \
--progress-every 100 \
--input-csv "/data7/sunxiuqiang/Biometric_Information_Extraction/don_text_extracted.csv" \
--output-excel "/data7/sunxiuqiang/Biometric_Information_Extraction/don_text_extracted_result_parallel.xlsx" \
--output-timing-csv "/data7/sunxiuqiang/Biometric_Information_Extraction/don_text_extracted_timing_parallel.csv" \
--progress-file "/data7/sunxiuqiang/Biometric_Information_Extraction/progress_don.csv" \
--dict-xlsx "/data7/sunxiuqiang/Biometric_Information_Extraction/dict_country_global_all.xlsx" \
--dict-pathogen-xlsx "/data7/sunxiuqiang/Biometric_Information_Extraction/dict_pathogen_feature.xlsx" \
--dict-host-xlsx "/data7/sunxiuqiang/Biometric_Information_Extraction/dict_host_tag.xlsx" \
--unmatched-file "/data7/sunxiuqiang/Biometric_Information_Extraction/unmatched_names_don.csv" \
--enable-llm-backfill \
--llm-backfill-timeout 120 \
--llm-backfill-retries 1 \
--llm-backfill-log-file "/data7/sunxiuqiang/Biometric_Information_Extraction/don_llm_backfill_log.csv"

# Monitoring (run manually in another shell):
# tail -f /data7/sunxiuqiang/Biometric_Information_Extraction/task_run.log
# grep -nE "Stage-2 backfill|stage-2 backfill progress|Done.|Output excel" /data7/sunxiuqiang/Biometric_Information_Extraction/task_run.log